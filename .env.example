# ── Gemini AI ────────────────────────────
# Your Gemini API Key from https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Application ──────────────────────────
APP_URL=http://localhost:3000

# ── Backend Server ───────────────────────
# Secret key for signing JWT tokens (use a strong random string in production)
JWT_SECRET=community-hero-dev-secret-change-in-production

# Path to the SQLite database file (default: server/community_hero.db)
DATABASE_PATH=server/community_hero.db

# Server port (default: 3001)
SERVER_PORT=3001
